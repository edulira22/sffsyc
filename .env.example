# =============================================================================
#  SFFSyC — Variables de entorno
#  Copia este archivo a ".env" y completa los valores reales.
#  NUNCA subas el archivo ".env" al repositorio (ya está en .gitignore).
# =============================================================================

# --- Base de datos PostgreSQL -------------------------------------------------
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASEDEDATOS?schema=public
# En el servidor del DIF, cambiar host/usuario/contraseña según corresponda.
DATABASE_URL="postgresql://dif_app:CAMBIAR_CONTRASEÑA@localhost:5432/sistema_dif?schema=public"

# --- Autenticación (NextAuth.js v5) ------------------------------------------
# Secreto para firmar las sesiones. Genera uno nuevo con:
#   npx auth secret      (o)    openssl rand -base64 32
AUTH_SECRET="GENERAR_UN_SECRETO_ALEATORIO"

# URL base de la aplicación. En local: http://localhost:3000
# En el servidor del DIF: la URL interna o el dominio institucional.
AUTH_URL="http://localhost:3000"

# --- Identidad del sistema (público) -----------------------------------------
NEXT_PUBLIC_NOMBRE_SISTEMA="SFFSyC"
NEXT_PUBLIC_NOMBRE_DEPENDENCIA="Subdirección de Fortalecimiento Familiar, Social y Comunitario"
